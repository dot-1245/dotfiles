/* 全体の設定 */
* {
    font-family: "PlemolJPConsoleNF-ExtraLight", sans-serif;
    font-size: 13px;
    border: none;
    border-radius: 0;
}

window#waybar {
    background: rgba(0, 0, 0, 0.5);
    color: #ffffff;
}

/* 48行目あたりのエラー箇所を削除し、padding で調整 */
#workspaces,
#custom-user,
#custom-playerpos,
#mpris,
#window,
#pulseaudio,
#network,
#cpu,
#memory,
#temperature,
#backlight,
#battery,
#clock,
#tray,
#custom-power {
    padding: 0 10px; /* ここを少し広めにとる */
}

#tray {
    margin-left: 15px;
}

/* トレイ内のアイコン自体の余白 */
#tray > .passive,
#tray > .active,
#tray > .needs-attention {
    padding: 0 5px;
}