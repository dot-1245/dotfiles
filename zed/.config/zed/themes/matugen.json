        "panel.background": "#14140c",
        "status_bar.background": "#14140c",
        "title_bar.background": "#14140c",
        "toolbar.background": "#14140c",
        "tab_bar.background": "#14140c",
        "tab.inactive_background": "#14140c",
        "tab.active_background": "#49473a",
        "editor.background": "#14140c",
        "editor.foreground": "#e6e2d5",
        "editor.line_number": "#949181",
        "editor.active_line_number": "#e6e2d5",
        "editor.selection.background": "#4b4900",
        "editor.active_line.background": "#49473a",
        "terminal.background": "#14140c",
        "terminal.foreground": "#e6e2d5",
        "text": "#e6e2d5",
