{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Matugen",
  "author": "matugen",
  "themes": [
    {
      "name": "Matugen",
      "appearance": "dark",
      "style": {
        "background": "#12131c",
        "background.appearance": "opaque",
        "elevated_surface.background": "#12131c",
        "surface.background": "#464651",
        "panel.background": "#12131c",
        "status_bar.background": "#12131c",
        "title_bar.background": "#12131c",
        "toolbar.background": "#12131c",
        "tab_bar.background": "#12131c",
        "tab.inactive_background": "#12131c",
        "tab.active_background": "#464651",
        "editor.background": "#12131c",
        "editor.foreground": "#e3e1ef",
        "editor.line_number": "#908f9c",
        "editor.active_line_number": "#e3e1ef",
        "editor.selection.background": "#0200ef",
        "editor.active_line.background": "#464651",
        "terminal.background": "#12131c",
        "terminal.foreground": "#e3e1ef",
        "text": "#e3e1ef",
        "text.muted": "#c7c5d3",
        "text.placeholder": "#908f9c",
        "text.disabled": "#908f9c",
        "text.accent": "#bfc2ff",
        "icon": "#e3e1ef",
        "icon.muted": "#908f9c",
        "icon.accent": "#bfc2ff",
        "border": "#464651",
        "border.variant": "#464651",
        "border.focused": "#bfc2ff",
        "border.selected": "#bfc2ff",
        "border.transparent": "#464651",
        "border.disabled": "#908f9c",
        "accent": "#bfc2ff",
        "error": "#ffb4ab",
        "error.background": "#93000a",
        "error.border": "#ffb4ab",
        "warning": "#dbbaf1",
        "success": "#ccc1e9",
        "syntax": {
          "keyword": { "color": "#bfc2ff", "font_style": null, "font_weight": null },
          "string": { "color": "#dbbaf1", "font_style": null, "font_weight": null },
          "function": { "color": "#ccc1e9", "font_style": null, "font_weight": null },
          "type": { "color": "#0200ef", "font_style": null, "font_weight": null },
          "comment": { "color": "#908f9c", "font_style": "italic", "font_weight": null },
          "number": { "color": "#e0e0ff", "font_style": null, "font_weight": null },
          "operator": { "color": "#e3e1ef", "font_style": null, "font_weight": null },
          "variable": { "color": "#e3e1ef", "font_style": null, "font_weight": null }
        }
      }
    }
