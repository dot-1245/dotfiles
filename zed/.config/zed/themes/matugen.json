        "elevated_surface.background": "#1c1108",
        "surface.background": "#544438",
        "panel.background": "#1c1108",
        "status_bar.background": "#1c1108",
        "title_bar.background": "#1c1108",
        "toolbar.background": "#1c1108",
        "tab_bar.background": "#1c1108",
        "tab.inactive_background": "#1c1108",
        "tab.active_background": "#544438",
        "editor.background": "#1c1108",
        "editor.foreground": "#f7dece",
        "editor.line_number": "#a18d7f",
        "editor.active_line_number": "#f7dece",
        "editor.selection.background": "#6e3900",
        "editor.active_line.background": "#544438",
        "terminal.background": "#1c1108",
        "terminal.foreground": "#f7dece",
        "text": "#f7dece",
