{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Matugen",
  "author": "matugen",
  "themes": [
    {
      "name": "Matugen",
      "appearance": "dark",
      "style": {
        "background": "#11131c",
        "background.appearance": "opaque",
        "elevated_surface.background": "#11131c",
        "surface.background": "#454651",
        "panel.background": "#11131c",
        "status_bar.background": "#11131c",
        "title_bar.background": "#11131c",
        "toolbar.background": "#11131c",
        "tab_bar.background": "#11131c",
        "tab.inactive_background": "#11131c",
        "tab.active_background": "#454651",
        "editor.background": "#11131c",
        "editor.foreground": "#e2e1ef",
        "editor.line_number": "#90909c",
        "editor.active_line_number": "#e2e1ef",
        "editor.selection.background": "#002bcf",
        "editor.active_line.background": "#454651",
        "terminal.background": "#11131c",
        "terminal.foreground": "#e2e1ef",
        "text": "#e2e1ef",
        "text.muted": "#c6c5d3",
        "text.placeholder": "#90909c",
        "text.disabled": "#90909c",
        "text.accent": "#bbc3ff",
        "icon": "#e2e1ef",
        "icon.muted": "#90909c",
        "icon.accent": "#bbc3ff",
        "border": "#454651",
        "border.variant": "#454651",
        "border.focused": "#bbc3ff",
        "border.selected": "#bbc3ff",
        "border.transparent": "#454651",
        "border.disabled": "#90909c",
        "accent": "#bbc3ff",
        "error": "#ffb4ab",
        "error.background": "#93000a",
        "error.border": "#ffb4ab",
        "warning": "#d8bbf3",
        "success": "#cac1ea",
        "syntax": {
          "keyword": { "color": "#bbc3ff", "font_style": null, "font_weight": null },
          "string": { "color": "#d8bbf3", "font_style": null, "font_weight": null },
          "function": { "color": "#cac1ea", "font_style": null, "font_weight": null },
          "type": { "color": "#002bcf", "font_style": null, "font_weight": null },
          "comment": { "color": "#90909c", "font_style": "italic", "font_weight": null },
          "number": { "color": "#dee0ff", "font_style": null, "font_weight": null },
          "operator": { "color": "#e2e1ef", "font_style": null, "font_weight": null },
          "variable": { "color": "#e2e1ef", "font_style": null, "font_weight": null }
        }
      }
    }
  ]
