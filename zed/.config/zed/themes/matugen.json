        "syntax": {
          "keyword": { "color": "#8cceff", "font_style": null, "font_weight": null },
          "string": { "color": "#bac4fa", "font_style": null, "font_weight": null },
          "function": { "color": "#b5c7e9", "font_style": null, "font_weight": null },
          "type": { "color": "#004b6f", "font_style": null, "font_weight": null },
          "comment": { "color": "#89929a", "font_style": "italic", "font_weight": null },
          "number": { "color": "#cae6ff", "font_style": null, "font_weight": null },
          "operator": { "color": "#dbe3ed", "font_style": null, "font_weight": null },
          "variable": { "color": "#dbe3ed", "font_style": null, "font_weight": null }
        }
      }
    }
