{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Matugen",
  "author": "matugen",
  "themes": [
    {
      "name": "Matugen",
      "appearance": "dark",
      "style": {
        "background": "#0c141b",
        "background.appearance": "opaque",
        "elevated_surface.background": "#0c141b",
        "surface.background": "#3f484f",
        "panel.background": "#0c141b",
        "status_bar.background": "#0c141b",
        "title_bar.background": "#0c141b",
        "toolbar.background": "#0c141b",
        "tab_bar.background": "#0c141b",
        "tab.inactive_background": "#0c141b",
        "tab.active_background": "#3f484f",
        "editor.background": "#0c141b",
        "editor.foreground": "#dbe3ed",
        "editor.line_number": "#89929a",
        "editor.active_line_number": "#dbe3ed",
        "editor.selection.background": "#004b6f",
        "editor.active_line.background": "#3f484f",
        "terminal.background": "#0c141b",
        "terminal.foreground": "#dbe3ed",
        "text": "#dbe3ed",
        "text.muted": "#bfc7d1",
        "text.placeholder": "#89929a",
        "text.disabled": "#89929a",
        "text.accent": "#8cceff",
        "icon": "#dbe3ed",
        "icon.muted": "#89929a",
        "icon.accent": "#8cceff",
        "border": "#3f484f",
        "border.variant": "#3f484f",
        "border.focused": "#8cceff",
        "border.selected": "#8cceff",
        "border.transparent": "#3f484f",
        "border.disabled": "#89929a",
        "accent": "#8cceff",
        "error": "#ffb4ab",
        "error.background": "#93000a",
        "error.border": "#ffb4ab",
        "warning": "#bac4fa",
