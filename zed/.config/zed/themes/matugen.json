          "comment": { "color": "#a18d7f", "font_style": "italic", "font_weight": null },
          "number": { "color": "#ffdcc3", "font_style": null, "font_weight": null },
          "operator": { "color": "#f7dece", "font_style": null, "font_weight": null },
          "variable": { "color": "#f7dece", "font_style": null, "font_weight": null }
