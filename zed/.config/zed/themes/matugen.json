          "function": { "color": "#cbc8a4", "font_style": null, "font_weight": null },
          "type": { "color": "#4b4900", "font_style": null, "font_weight": null },
          "comment": { "color": "#949181", "font_style": "italic", "font_weight": null },
          "number": { "color": "#ebe68e", "font_style": null, "font_weight": null },
