{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Matugen",
  "author": "matugen",
  "themes": [
    {
      "name": "Matugen",
      "appearance": "dark",
      "style": {
        "background": "{{ colors.background.default.hex }}",
        "background.appearance": "opaque",
        "elevated_surface.background": "{{ colors.surface.default.hex }}",
        "surface.background": "{{ colors.surface_variant.default.hex }}",
        "panel.background": "{{ colors.surface.default.hex }}",
        "status_bar.background": "{{ colors.surface.default.hex }}",
        "title_bar.background": "{{ colors.surface.default.hex }}",
        "toolbar.background": "{{ colors.surface.default.hex }}",
        "tab_bar.background": "{{ colors.surface.default.hex }}",
        "tab.inactive_background": "{{ colors.surface.default.hex }}",
        "tab.active_background": "{{ colors.surface_variant.default.hex }}",
        "editor.background": "{{ colors.background.default.hex }}",
        "editor.foreground": "{{ colors.on_background.default.hex }}",
        "editor.line_number": "{{ colors.outline.default.hex }}",
        "editor.active_line_number": "{{ colors.on_surface.default.hex }}",
        "editor.selection.background": "{{ colors.primary_container.default.hex }}",
        "editor.active_line.background": "{{ colors.surface_variant.default.hex }}",
        "terminal.background": "{{ colors.background.default.hex }}",
        "terminal.foreground": "{{ colors.on_background.default.hex }}",
        "text": "{{ colors.on_background.default.hex }}",
        "text.muted": "{{ colors.on_surface_variant.default.hex }}",
        "text.placeholder": "{{ colors.outline.default.hex }}",
        "text.disabled": "{{ colors.outline.default.hex }}",
        "text.accent": "{{ colors.primary.default.hex }}",
        "icon": "{{ colors.on_surface.default.hex }}",
        "icon.muted": "{{ colors.outline.default.hex }}",
        "icon.accent": "{{ colors.primary.default.hex }}",
        "border": "{{ colors.outline_variant.default.hex }}",
        "border.variant": "{{ colors.outline_variant.default.hex }}",
        "border.focused": "{{ colors.primary.default.hex }}",
        "border.selected": "{{ colors.primary.default.hex }}",
        "border.transparent": "{{ colors.outline_variant.default.hex }}",
        "border.disabled": "{{ colors.outline.default.hex }}",
        "accent": "{{ colors.primary.default.hex }}",
        "error": "{{ colors.error.default.hex }}",
        "error.background": "{{ colors.error_container.default.hex }}",
        "error.border": "{{ colors.error.default.hex }}",
        "warning": "{{ colors.tertiary.default.hex }}",
        "success": "{{ colors.secondary.default.hex }}",
        "syntax": {
          "keyword": { "color": "{{ colors.primary.default.hex }}", "font_style": null, "font_weight": null },
          "string": { "color": "{{ colors.tertiary.default.hex }}", "font_style": null, "font_weight": null },
          "function": { "color": "{{ colors.secondary.default.hex }}", "font_style": null, "font_weight": null },
          "type": { "color": "{{ colors.primary_container.default.hex }}", "font_style": null, "font_weight": null },
          "comment": { "color": "{{ colors.outline.default.hex }}", "font_style": "italic", "font_weight": null },
          "number": { "color": "{{ colors.on_primary_container.default.hex }}", "font_style": null, "font_weight": null },
          "operator": { "color": "{{ colors.on_surface.default.hex }}", "font_style": null, "font_weight": null },
          "variable": { "color": "{{ colors.on_background.default.hex }}", "font_style": null, "font_weight": null }
        }
      }
    }
  ]
}
